{
    "name": "qa-generator",
    "version": "1.0.0",
    "scripts": {
        "start": "node server.js",
        "test": "jest --runInBand --forceExit",
        "test:watch": "jest --watch",
        "dev": "concurrently \"node server.js\" \"npm run dev --prefix client\"",
        "vercel-build": "node scripts/vercel-build.js"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": [
            "**/tests/**/*.test.js"
        ]
    },
    "dependencies": {
        "archiver": "^6.0.1",
        "axios": "^1.6.0",
        "cors": "^2.8.5",
        "docx": "^9.7.1",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "mammoth": "^1.7.0",
        "multer": "^1.4.5-lts.1",
        "pdf-parse": "^1.1.1",
        "pdfkit": "^0.19.1",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "concurrently": "^10.0.3",
        "jest": "^29.7.0",
        "supertest": "^6.3.4"
    }
}
